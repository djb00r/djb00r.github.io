// AI equation: one simple arithmetic way to build the number
async function equationForNumberAI(valueStr) {
  const isInteger = !valueStr.includes(".");
  const fallback = (() => {
    // Simple deterministic fallback if AI isn't available
    if (isInteger) {
      try {
        const n = BigInt(valueStr);
        if (n === 0n) return "0 = 0 × 1";
        if (n === 1n) return "1 = 1 + 0";
        if (n === 2n) return "2 = 1 + 1";
        if (n === 3n) return "3 = 1 + 2";
        if (n > 0n) {
          return `${n} = ${n - 1n} + 1`;
        }
        // negative
        return `${n} = 0 - ${-n}`;
      } catch {
        // fall through if BigInt fails
      }
    }
    // For non-integers or huge integers
    return `${valueStr} ≈ ${valueStr} × 1`;
  })();

  if (
    typeof websim === "undefined" ||
    !websim.chat ||
    !websim.chat.completions ||
    !aiSummariesEnabled
  ) {
    return fallback;
  }

  try {
    const completion = await websim.chat.completions.create({
      messages: [
        {
          role: "system",
          content:
            "You output one short arithmetic expression that evaluates to the given number. Use only +, -, ×, ÷, and exponents (^). Prefer very simple, human-style equations like '1 + 1 = 2', '99 - 10 = 89', or '3 × 3 = 9'. If the number is not an integer, you can still show a simple decimal expression. Respond with just the equation, nothing else.",
        },
        {
          role: "user",
          content: `Number: ${valueStr}`,
        },
      ],
    });

    const text =
      (completion && completion.content && completion.content.trim()) || "";
    return text || fallback;
  } catch {
    return fallback;
  }
}

// Background effects

function applyNumberEffects(page) {
  // Always clear existing background classes
  document.body.classList.remove(...BG_CLASSES);

  if (!numberEffectsEnabled) {
    // Fall back to the base CSS background
    return;
  }

  let cls = "bg-default";

  if (page <= BG_THRESHOLDS.NEGATIVE_MAX) {
    cls = "bg-negative";
  } else if (page <= BG_THRESHOLDS.DEFAULT_MAX) {
    cls = "bg-default";
  } else if (page <= BG_THRESHOLDS.GREEN_MAX) {
    cls = "bg-green";
  } else if (page <= BG_THRESHOLDS.RED_MAX) {
    cls = "bg-red";
  } else if (page <= BG_THRESHOLDS.PINK_MAX) {
    cls = "bg-pink";
  } else if (page <= BG_THRESHOLDS.GLITCH_DARK_MAX) {
    cls = "bg-glitch-dark";
  } else if (page <= BG_THRESHOLDS.GLITCH_LIGHT_MAX) {
    cls = "bg-glitch-light";
  } else if (page < BG_THRESHOLDS.BINARY_START) {
    // Between 2.5×10^11 and 10^13: treat as lighter glitchy color already handled above
    cls = "bg-glitch-light";
  } else if (page <= BG_THRESHOLDS.BINARY_GLITCH_MAX) {
    cls = "bg-binary";
  } else if (page < BG_THRESHOLDS.BINARY_TRUE_START) {
    cls = "bg-binary-glitch";
  } else {
    cls = "bg-binary-true";
  }

  document.body.classList.add(cls);
}
